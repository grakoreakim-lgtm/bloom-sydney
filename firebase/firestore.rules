rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read: today's product listing
    match /daily_products/{date} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Customer-facing product catalogue: anyone can read, only signed-in users (= admin) write.
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Store settings (delivery fees, cutoff time, etc.): public read so customer page can use,
    // only signed-in admin can edit.
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: customer site may CREATE (for future Stripe checkout). Read/update/delete admin-only.
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Customers: admin-only (auto-created by admin when an order is saved).
    match /customers/{email} {
      allow read, write: if request.auth != null;
    }

    // FAQs: public read, auth-only write.
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reviews: public read, auth-only write.
    // (Phase B: customer-side review submission will need a separate /pending_reviews flow.)
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Custom order requests: public CREATE (so customer site form works),
    // admin-only read/update/delete.
    match /customOrders/{reqId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Blog posts: public read (SEO), admin-only write.
    match /blog/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Public read: Instagram feed cache
    match /cache/{doc} {
      allow read: if true;
      allow write: if false; // Functions only
    }

    // Admin push-notification devices: each doc id is an FCM token.
    // Any signed-in admin can register/refresh their own token, and read the list.
    // Cloud Functions read this list with the admin SDK, bypassing rules.
    match /admin_devices/{token} {
      allow read, write: if request.auth != null;
    }

    // Customer anniversaries (sub-collection of customers)
    match /customers/{email}/anniversaries/{annivId} {
      allow read, write: if request.auth != null;
    }

    // Subscriptions: signed-in users (= admin) only
    match /subscriptions/{subId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }
  }
}
